{
  "//": "Manual (non-plugin) install of goal. The goal cockpit is wired into the status line ADDITIVELY by bin/goal-statusline-install, which the installer runs for you — it preserves any status line you already have. statusLine and the SessionStart hook below are shown for reference; for a fresh install you can copy them verbatim.",
  "statusLine": {
    "type": "command",
    "command": "bash $HOME/.claude/hooks/goal-statusline-wrap.sh",
    "refreshInterval": 10
  },
  "hooks": {
    "SessionStart": [
      { "hooks": [ { "type": "command", "command": "bash $HOME/.claude/bin/goal-statusline-install --ensure" } ] }
    ],
    "Stop": [
      { "hooks": [ { "type": "command", "command": "GOAL_STOP_PROMPT_STYLE=compact bash $HOME/.claude/hooks/goal-stop.sh" } ] }
    ],
    "Notification": [
      { "hooks": [ { "type": "command", "command": "bash $HOME/.claude/hooks/goal-notify.sh" } ] }
    ],
    "UserPromptSubmit": [
      { "hooks": [ { "type": "command", "command": "bash $HOME/.claude/hooks/goal-prompt.sh" } ] }
    ]
  }
}
