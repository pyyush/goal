#!/usr/bin/env bash
# goalctl — headless CLI for the v3 /goal state.
#
# Drives a Codex-style session-owned goal from outside Claude Code: CI jobs,
# multi-agent runners, IDE plugins, shell automation. v3 layout:
#
#   .goal/goals/<goal_id>.json       one record per goal
#   .goal/sessions/<session_id>      pointer (text = goal_id) for session-owned resolution
#   .goal/locks/<goal_id>.lock       per-goal mkdir mutex
#   .goal/locks/_coord.lock          cross-goal coordination lock
#
# Resolution: --goal/--session flags override; otherwise read
# CLAUDE_SESSION_ID / GOAL_SESSION_ID env vars; otherwise fall back to the
# project's single non-terminal goal if there's exactly one (RFC §3.2). A v2
# .goal/state.json is migrated forward to .goal/goals/<gid>.json on first touch
# and left unowned (per RFC §5: the next /goal create or /goal adopt binds).
#
# Requires: bash 3.2+, jq, uuidgen (or /proc/sys/kernel/random/uuid).

set -euo pipefail

die() { printf 'goalctl: %s\n' "$*" >&2; exit 1; }

usage() {
    cat <<EOF
usage: goalctl [global-opts] <command> [args]

commands:
  create <objective> [--budget N]   create a new goal (one per session)
  replace <objective> [--budget N]  replace the session's existing goal
  adopt <goal_id>                   bind this session to an existing goal
  get [--json]                      print the goal record
  status [--json]                   print a one-line status (--json: structured)
  pause                             set status=paused
  resume                            set status=pursuing
  clear                             delete the goal record + session pointer
  set-budget <N>                    update token_budget (positive int or 'none')
  mark-achieved                     set status=achieved (skips audit — caller-owned)
  list [--json]                     list all goals in the project
  listen [--grep PAT] [--since ISO] tail .goal/events.jsonl
  serve-http [--port N]             local HTTP shim (loopback only, default 7474)
  bridge start <runner>             start goal-bridge for <runner> in background
  bridge stop <runner>              stop goal-bridge for <runner>
  handoff list [--json]             list handoff envelopes in .goal/handoff/
  handoff show <seq> [--json]       show a specific handoff envelope
  lanes [--json]                    list current lane leases
  lanes release <lease_id>          release a lane lease
  relay [--json]                    force relay to peer (writes fault signal)
  quota [--json]                    show provider headroom from .goal/quota.json
  cowork init                       write default .goal/cowork.yml
  watch [--allow-control]           render the read-only v3 dashboard
  history list|show <id>            list or inspect archived goals
  debrief [--publish DEST]          generate or publish a goal debrief
  pr [--draft]                      scaffold PR title/body/labels (no push)
  sync push|pull                    sync .goal/ through goal-state branch
  backlog [next]                    list or promote backlog items
  template list                     list/materialize shipped goal templates
  notifier start|stop               manage notification marker

global options:
  --root <dir>      project root (walks up from \$PWD otherwise)
  --goal <gid>      target this exact goal id (overrides session resolution)
  --session <sid>   resolve via this session pointer (overrides CLAUDE_SESSION_ID)
  --json            machine-readable output

env:
  CLAUDE_SESSION_ID / GOAL_SESSION_ID   resolve which goal this session owns
  GOAL_DISABLE_MIGRATION=1              skip v1→v2→v3 forward migration

There is no \`mark-unmet\` / \`abandon\` route in v3 — a stuck goal parks to
\`needs-input\` automatically and remains resumable; only the user clears.
EOF
}

# ---- arg parsing -----------------------------------------------------------

ROOT_OVERRIDE=""
JSON_OUTPUT=0
GOAL_OVERRIDE=""
SESSION_OVERRIDE=""
ARGS=()
while [ $# -gt 0 ]; do
    case "$1" in
        --root) ROOT_OVERRIDE="$2"; shift 2 ;;
        --json) JSON_OUTPUT=1; shift ;;
        --goal) GOAL_OVERRIDE="$2"; shift 2 ;;
        --session) SESSION_OVERRIDE="$2"; shift 2 ;;
        -h|--help) usage; exit 0 ;;
        *) ARGS+=("$1"); shift ;;
    esac
done

[ "${#ARGS[@]}" -eq 0 ] && { usage; exit 1; }
CMD="${ARGS[0]}"
ARGS=("${ARGS[@]:1}")

# ---- resolve root ----------------------------------------------------------

resolve_root() {
    if [ -n "$ROOT_OVERRIDE" ]; then
        [ -d "$ROOT_OVERRIDE" ] || die "--root: not a directory: $ROOT_OVERRIDE"
        printf '%s' "$ROOT_OVERRIDE"
        return
    fi
    local d="$PWD"
    while [ "$d" != "/" ] && [ "$d" != "$HOME" ] && [ -n "$d" ]; do
        # v3: .goal/ directory anywhere up the tree.
        if [ -d "$d/.goal" ] && [ ! -L "$d/.goal" ]; then
            printf '%s' "$d"
            return
        fi
        # v1 legacy: .claude/goal.json.
        if [ -f "$d/.claude/goal.json" ] && [ ! -L "$d/.claude/goal.json" ]; then
            printf '%s' "$d"
            return
        fi
        d=$(dirname "$d")
    done
    # No existing goal found — for create/listen/serve-http/cowork init, use $PWD. Else fail.
    case "$CMD" in
        create|listen|serve-http|cowork) printf '%s' "$PWD" ;;
        *) die "no goal state found (walked up from $PWD). Did you mean: goalctl create <objective>?" ;;
    esac
}

# session_id: pick the session id for resolution.
#   1) --session flag (explicit override)
#   2) CLAUDE_SESSION_ID env (set by Claude Code when launching MCP servers)
#   3) GOAL_SESSION_ID env (test/explicit override)
# Empty if none — callers fall back to single-active resolution.
session_id() {
    if [ -n "$SESSION_OVERRIDE" ]; then
        printf '%s' "$SESSION_OVERRIDE"; return
    fi
    if [ -n "${CLAUDE_SESSION_ID:-}" ]; then
        printf '%s' "$CLAUDE_SESSION_ID"; return
    fi
    if [ -n "${GOAL_SESSION_ID:-}" ]; then
        printf '%s' "$GOAL_SESSION_ID"; return
    fi
    printf ''
}

# valid_uuid <s> — exit 0 if s looks like a v3 goal_id (UUID-shaped, no path tricks).
valid_uuid() {
    [[ "$1" =~ ^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$ ]]
}

# resolve_goal_record <root> — print the path of the goal record for this
# call. Resolution order (matches mcp/goal-server.ts):
#   1) --goal <gid>          explicit
#   2) sessions/<sid> ptr    where sid comes from --session / CLAUDE_SESSION_ID / GOAL_SESSION_ID
#   3) single-active         if exactly one non-terminal goal exists in the project
# Exits non-zero if nothing resolves and the command requires a target.
resolve_goal_record() {
    local root="$1"
    local goals_dir="$root/.goal/goals"

    # 1) Explicit --goal
    if [ -n "$GOAL_OVERRIDE" ]; then
        valid_uuid "$GOAL_OVERRIDE" || die "--goal: not a valid goal_id: $GOAL_OVERRIDE"
        local f="$goals_dir/$GOAL_OVERRIDE.json"
        [ -f "$f" ] && [ ! -L "$f" ] || die "--goal: no record at $f"
        printf '%s' "$f"; return 0
    fi

    # 2) Session pointer
    local sid; sid=$(session_id)
    if [ -n "$sid" ]; then
        local ptr="$root/.goal/sessions/$sid"
        if [ -f "$ptr" ] && [ ! -L "$ptr" ]; then
            local gid
            gid=$(tr -d ' \t\r\n' < "$ptr" 2>/dev/null || true)
            if valid_uuid "$gid"; then
                local f="$goals_dir/$gid.json"
                if [ -f "$f" ] && [ ! -L "$f" ]; then
                    local on_disk
                    on_disk=$(jq -r '.goal_id // ""' "$f" 2>/dev/null || true)
                    if [ "$on_disk" = "$gid" ]; then
                        printf '%s' "$f"; return 0
                    fi
                fi
            fi
        fi
    fi

    # 3) Single-active fallback — exactly one non-terminal goal.
    if [ -d "$goals_dir" ]; then
        local active=()
        local f
        for f in "$goals_dir"/*.json; do
            [ -f "$f" ] && [ ! -L "$f" ] || continue
            local st
            st=$(jq -r '.status // ""' "$f" 2>/dev/null || echo "")
            case "$st" in
                pursuing|paused|needs-input|relaying|queued) active+=("$f") ;;
            esac
        done
        if [ "${#active[@]}" -eq 1 ]; then
            printf '%s' "${active[0]}"; return 0
        fi
        if [ "${#active[@]}" -gt 1 ]; then
            die "multiple active goals in $root/.goal/goals/ — pass --goal <gid> or --session <sid> to disambiguate"
        fi
    fi

    return 1
}

# legacy_v2_state_file <root> — if a pre-migration .goal/state.json is present,
# return its path. Callers run goalctl_migrate_forward first.
legacy_v2_state_file() {
    local f="$1/.goal/state.json"
    [ "${GOAL_DISABLE_MIGRATION:-0}" = "1" ] && return 1
    [ -f "$f" ] && [ ! -L "$f" ] && { printf '%s' "$f"; return 0; }
    return 1
}

# goalctl_migrate_forward: idempotent v1→v2→v3 forward migration.
#
#   v1 → v2:  .claude/goal.json    → .goal/state.json
#   v2 → v3:  .goal/state.json     → .goal/goals/<gid>.json
#
# Runs before any read/write so the on-disk shape matches what the v3 resolver
# expects. Migrating records are left UNOWNED (RFC §5: the next /goal create or
# /goal adopt binds a session). Best-effort: failures log to .claude/goal-hook.log
# and leave the previous state in place. Honors GOAL_DISABLE_MIGRATION=1.
goalctl_migrate_forward() {
    local root="$1"
    local v1_file="$root/.claude/goal.json"
    local goal_dir="$root/.goal"
    local v2_file="$goal_dir/state.json"
    local goals_dir="$goal_dir/goals"
    local log_file="$root/.claude/goal-hook.log"
    local marker_file="$root/.claude/MIGRATED_TO_GOAL"

    [ "${GOAL_DISABLE_MIGRATION:-0}" = "1" ] && return 0

    # Stage 1: v1 → v2 (rare in practice; only triggers if .goal/ is absent).
    if [ -f "$v1_file" ] && [ ! -L "$v1_file" ] && [ ! -d "$goal_dir" ]; then
        _goalctl_migrate_v1_to_v2 "$root" || true
    fi

    # Stage 2: v2 → v3 (the common case post-merge).
    if [ -f "$v2_file" ] && [ ! -L "$v2_file" ] && [ ! -e "$goals_dir/$(jq -r '.goal_id // "_none_"' "$v2_file" 2>/dev/null).json" ]; then
        _goalctl_migrate_v2_to_v3 "$root" || true
    fi
    return 0
}

_goalctl_migrate_v1_to_v2() {
    local root="$1"
    local v1_file="$root/.claude/goal.json"
    local goal_dir="$root/.goal"
    local v2_file="$goal_dir/state.json"
    local log_file="$root/.claude/goal-hook.log"
    local marker_file="$root/.claude/MIGRATED_TO_GOAL"

    mkdir -p "$root/.claude" 2>/dev/null || true
    local lockdir="$root/.claude/goal.lock"
    if ! goal_lock_acquire "$lockdir"; then
        printf 'goalctl: v1→v2 migration: could not acquire .claude/goal.lock; skipping\n' >&2
        return 1
    fi
    trap 'goal_lock_release "$lockdir"' EXIT INT TERM

    if [ -d "$goal_dir" ]; then
        goal_lock_release "$lockdir"; trap - EXIT INT TERM; return 0
    fi

    local tmp_dir
    tmp_dir=$(mktemp -d "$root/.claude/.goal-migrate-XXXXXX") || {
        goal_lock_release "$lockdir"; trap - EXIT INT TERM
        printf 'goalctl: v1→v2 migration: mktemp failed\n' >&2; return 1
    }
    local tmp_state="$tmp_dir/state.json"

    if ! jq '
        (.status // "pursuing") as $status
        | (.tick_count // 0) as $ticks
        | (.tokens_used // 0) as $tokens
        | (.pursuing_seconds // 0) as $psecs
        | (.created_at // (now | todateiso8601)) as $created
        | (.updated_at // (now | todateiso8601)) as $updated
        | (if ($status == "pursuing" or $status == "paused") then null else $updated end) as $ended
        | . + {
            schema_version: 2,
            time_used_seconds: $psecs,
            observed_at: $updated,
            active_turn_started_at: (if $status == "pursuing" then (.pursuing_since // $updated) else null end),
            tokens_used_observed_at: $updated,
            time_used_seconds_final: (if $ended == null then null else $psecs end),
            tokens_used_final: (if $ended == null then null else $tokens end),
            compat: ["claude-code"],
            roles: { lead: null, build: null, review: null },
            current: { agent: null, session: null, since: null },
            budget: null,
            lineage: [{ agent: "claude-code", model: "unknown", started_at: $created,
                        ended_at: $ended, turns: $ticks, tokens: $tokens,
                        summary: "migrated from v1" }],
            audit: null, handoff_head: null, queued_until: null
          }' "$v1_file" > "$tmp_state" 2>/dev/null; then
        rm -rf "$tmp_dir" 2>/dev/null || true
        goal_lock_release "$lockdir"; trap - EXIT INT TERM
        printf 'goalctl: v1→v2 migration: jq transform failed; leaving v1 in place\n' >&2
        return 1
    fi

    mkdir -p "$goal_dir" 2>/dev/null || true
    if ! mv "$tmp_state" "$v2_file" 2>/dev/null; then
        rm -rf "$tmp_dir" 2>/dev/null || true
        rmdir "$goal_dir" 2>/dev/null || true
        goal_lock_release "$lockdir"; trap - EXIT INT TERM
        printf 'goalctl: v1→v2 migration: mv failed; leaving v1 in place\n' >&2
        return 1
    fi
    rm -rf "$tmp_dir" 2>/dev/null || true
    rm -rf "$root/.claude/goal.lock" 2>/dev/null || true
    printf '%s\n' "$(date -u +%FT%TZ)" > "$marker_file" 2>/dev/null || true
    {
        printf '{"ts":"%s","pid":%d,"cmd":"goalctl","event":"migration-v1-v2-done","root":"%s"}\n' \
            "$(date -u +%FT%TZ)" "$$" "$root"
    } >> "$log_file" 2>/dev/null || true
    goal_lock_release "$lockdir"; trap - EXIT INT TERM
    return 0
}

_goalctl_migrate_v2_to_v3() {
    local root="$1"
    local goal_dir="$root/.goal"
    local v2_file="$goal_dir/state.json"
    local goals_dir="$goal_dir/goals"
    local locks_dir="$goal_dir/locks"
    local log_file="$root/.claude/goal-hook.log"

    [ -f "$v2_file" ] && [ ! -L "$v2_file" ] || return 0

    mkdir -p "$goals_dir" "$locks_dir" 2>/dev/null || true
    local lockdir="$locks_dir/_coord.lock"
    if ! goal_lock_acquire "$lockdir"; then
        printf 'goalctl: v2→v3 migration: could not acquire %s; skipping\n' "$lockdir" >&2
        return 1
    fi
    trap 'goal_lock_release "$lockdir"' EXIT INT TERM

    # Race-free re-check.
    if [ ! -f "$v2_file" ] || [ -L "$v2_file" ]; then
        goal_lock_release "$lockdir"; trap - EXIT INT TERM; return 0
    fi

    local gid
    gid=$(jq -r '.goal_id // ""' "$v2_file" 2>/dev/null || echo "")
    if ! valid_uuid "$gid"; then
        goal_lock_release "$lockdir"; trap - EXIT INT TERM
        printf 'goalctl: v2→v3 migration: state.json has no valid goal_id (got "%s"); leaving in place\n' "$gid" >&2
        return 1
    fi

    local target="$goals_dir/$gid.json"
    if [ -f "$target" ]; then
        # Target already exists (idempotent re-run, or another writer beat us).
        # Prefer the v3 record; drop the legacy file.
        rm -f "$v2_file" 2>/dev/null || true
        goal_lock_release "$lockdir"; trap - EXIT INT TERM
        return 0
    fi

    # mv is atomic on the same filesystem.
    if ! mv "$v2_file" "$target" 2>/dev/null; then
        goal_lock_release "$lockdir"; trap - EXIT INT TERM
        printf 'goalctl: v2→v3 migration: mv %s → %s failed\n' "$v2_file" "$target" >&2
        return 1
    fi

    {
        printf '{"ts":"%s","pid":%d,"cmd":"goalctl","event":"migration-v2-v3-done","goal_id":"%s","root":"%s"}\n' \
            "$(date -u +%FT%TZ)" "$$" "$gid" "$root"
    } >> "$log_file" 2>/dev/null || true
    # Emit a one-line event to events.jsonl too, so the MCP and other readers see it.
    printf '{"ts":"%s","type":"goal.migrated","goal_id":"%s","note":"v2 state.json → v3 goals/<gid>.json (unowned; bind via goalctl adopt)"}\n' \
        "$(date -u +%FT%TZ)" "$gid" >> "$goal_dir/events.jsonl" 2>/dev/null || true

    goal_lock_release "$lockdir"; trap - EXIT INT TERM
    return 0
}

# Source the lock helper FIRST so the migration helpers can call it. Discovery:
#   1) $GOAL_LOCK_SH (explicit override)
#   2) <repo>/hooks/goal-lock.sh (in-repo: bin/ and hooks/ are siblings)
#   3) ~/.claude/hooks/goal-lock.sh (user-scope install)
__GOAL_LOCK_FOUND=0
if [ -n "${GOAL_LOCK_SH:-}" ] && [ -r "$GOAL_LOCK_SH" ]; then
    # shellcheck disable=SC1090
    . "$GOAL_LOCK_SH"; __GOAL_LOCK_FOUND=1
else
    __GC_DIR="$(cd "$(dirname "$0")" && pwd)"
    for __cand in "$__GC_DIR/../hooks/goal-lock.sh" "$HOME/.claude/hooks/goal-lock.sh"; do
        if [ -r "$__cand" ]; then
            # shellcheck disable=SC1090
            . "$__cand"; __GOAL_LOCK_FOUND=1; break
        fi
    done
fi
if [ "$__GOAL_LOCK_FOUND" -eq 0 ]; then
    printf 'goalctl: warning — goal-lock.sh not found; concurrent writes may lose updates\n' >&2
    goal_lock_acquire() { return 0; }
    goal_lock_release() { :; }
fi

ROOT=$(resolve_root)
goalctl_migrate_forward "$ROOT" || true
NOW=$(date -u +%FT%TZ)
# Goal record / id for THIS call. Empty if no goal resolves (handled per-cmd).
FILE=""
GID=""
if RESOLVED=$(resolve_goal_record "$ROOT" 2>/dev/null); then
    FILE="$RESOLVED"
    GID=$(basename "$FILE" .json)
fi
SID=$(session_id)

# ---- helpers ---------------------------------------------------------------

new_uuid() {
    if command -v uuidgen >/dev/null 2>&1; then
        uuidgen | tr 'A-Z' 'a-z'
    elif [ -r /proc/sys/kernel/random/uuid ]; then
        cat /proc/sys/kernel/random/uuid
    else
        # Fallback: not RFC4122 but unique enough.
        printf '%08x-%04x-%04x-%04x-%012x' \
            $((RANDOM*RANDOM)) $RANDOM $RANDOM $RANDOM $((RANDOM*RANDOM*RANDOM))
    fi
}

read_field() { jq -r "$1 // empty" "$FILE" 2>/dev/null; }

# compute_pursuit_seconds: reads pursuing_since from $FILE and prints the
# integer seconds elapsed since that timestamp (now - pursuing_since). Prints
# 0 if pursuing_since is missing/null/unparseable. Portable: uses python3 if
# available, else falls back to jq's fromdateiso8601 (which works on macOS and
# Linux without date(1) flag differences).
compute_pursuit_seconds() {
    local f="${1:-$FILE}"
    [ -f "$f" ] || { printf '0'; return; }
    jq -r '
        (try (.pursuing_since | fromdateiso8601) catch null) as $since
        | if $since == null then 0
          else (now - ($since | floor)) | floor
            | if . < 0 then 0 else . end
          end
    ' "$f" 2>/dev/null || printf '0'
}

# write_state: RMW on the resolved per-goal record under its per-goal lock.
write_state() {
    # $1 = jq filter that mutates ., applied to current $FILE.
    [ -n "$FILE" ] || die "write_state: no goal record resolved"
    [ -n "$GID" ] || die "write_state: no goal id"
    local lockdir="$ROOT/.goal/locks/$GID.lock"
    mkdir -p "$(dirname "$lockdir")" 2>/dev/null || true
    if ! goal_lock_acquire "$lockdir"; then
        die "could not acquire $lockdir (held by another writer for >${GOAL_LOCK_TIMEOUT_MS:-5000}ms)"
    fi
    trap 'goal_lock_release "$lockdir"' EXIT INT TERM
    local file_dir tmp
    file_dir=$(dirname "$FILE")
    tmp=$(mktemp "$file_dir/.state.XXXXXX")
    if jq --arg ts "$NOW" "$1" "$FILE" > "$tmp" 2>/dev/null; then
        mv "$tmp" "$FILE"
    else
        rm -f "$tmp"
        goal_lock_release "$lockdir"
        trap - EXIT INT TERM
        die "jq filter failed; goal state unchanged"
    fi
    goal_lock_release "$lockdir"
    trap - EXIT INT TERM
}

# write_new_record: create a brand-new goal record (gid not pre-existing).
# Takes the project-coord lock so concurrent create_goal calls serialize.
# Usage: write_new_record <target-path> <command> [args...]
write_new_record() {
    local target="$1"; shift
    local lockdir="$ROOT/.goal/locks/_coord.lock"
    mkdir -p "$(dirname "$lockdir")" 2>/dev/null || true
    if ! goal_lock_acquire "$lockdir"; then
        die "could not acquire $lockdir (held by another writer for >${GOAL_LOCK_TIMEOUT_MS:-5000}ms)"
    fi
    trap 'goal_lock_release "$lockdir"' EXIT INT TERM
    local file_dir tmp
    file_dir=$(dirname "$target")
    mkdir -p "$file_dir" 2>/dev/null || true
    tmp=$(mktemp "$file_dir/.state.XXXXXX")
    if "$@" > "$tmp"; then
        mv "$tmp" "$target"
    else
        rm -f "$tmp" 2>/dev/null || true
        goal_lock_release "$lockdir"
        trap - EXIT INT TERM
        die "state generation failed; goal record not written"
    fi
    goal_lock_release "$lockdir"
    trap - EXIT INT TERM
}

ensure_exists() {
    [ -n "$FILE" ] && [ -f "$FILE" ] || die "no goal resolved (try: goalctl list, or pass --goal <gid>)"
}

ensure_dir() {
    mkdir -p "$ROOT/.claude" 2>/dev/null || true
    mkdir -p "$ROOT/.goal/goals" "$ROOT/.goal/sessions" "$ROOT/.goal/locks" "$ROOT/.goal/cursors" 2>/dev/null || true
}

# atomic_write_session_pointer <sid> <gid>
atomic_write_session_pointer() {
    local sid="$1" gid="$2"
    local dir="$ROOT/.goal/sessions"
    mkdir -p "$dir" 2>/dev/null || true
    local ptr="$dir/$sid"
    local tmp; tmp=$(mktemp "$dir/.ptr.XXXXXX") || die "session pointer: mktemp failed"
    printf '%s\n' "$gid" > "$tmp"
    mv "$tmp" "$ptr" 2>/dev/null || { rm -f "$tmp"; die "session pointer: mv failed"; }
}

append_history() {
    # $1=action $2=note
    write_state ".history = ((.history // []) + [{ts: \$ts, action: \"$1\", note: \"$2\"}]) | .updated_at = \$ts"
}

# ---- commands --------------------------------------------------------------

case "$CMD" in

watch|history|debrief|pr|sync|backlog|template|notifier)
    V3="$(cd "$(dirname "$0")" && pwd)/goal-v3"
    [ -x "$V3" ] || die "goal-v3 helper not found at $V3"
    exec node "$V3" "$CMD" "$ROOT" "$JSON_OUTPUT" ${ARGS[@]+"${ARGS[@]}"}
    ;;

create|replace)
    QUICK=0
    TEMPLATE=""
    DECOMPOSE=0
    BUDGET="null"
    OBJ_PARTS=()
    i=0
    while [ "$i" -lt "${#ARGS[@]}" ]; do
        case "${ARGS[$i]}" in
            --quick)     QUICK=1; i=$((i+1)) ;;
            --template)  TEMPLATE="${ARGS[$((i+1))]:-}"
                         [ -n "$TEMPLATE" ] || die "--template requires a name"
                         i=$((i+2)) ;;
            --decompose) DECOMPOSE=1; i=$((i+1)) ;;
            --budget)    BUDGET="${ARGS[$((i+1))]:-}"
                         [[ "$BUDGET" =~ ^[1-9][0-9]*$ ]] || die "--budget must be a positive integer"
                         i=$((i+2)) ;;
            *)           OBJ_PARTS+=("${ARGS[$i]}"); i=$((i+1)) ;;
        esac
    done
    OBJECTIVE="${OBJ_PARTS[*]:-}"
    [ -z "$OBJECTIVE" ] && die "$CMD: objective required"
    OBJ_LEN=$(printf '%s' "$OBJECTIVE" | wc -m | tr -d '[:space:]')
    [ "$OBJ_LEN" -le 4000 ] || die "objective is $OBJ_LEN characters; limit is 4000"

    ensure_dir
    # v3 ownership check: only look at the goal THIS session already owns. Do
    # NOT fall back to single-active here — two sessions in one folder are
    # independent (each gets its own goal record + pointer). For sessions with
    # no pointer (CI runs, scripts, fresh terminals) AND no --session flag,
    # we still need to be conservative: refuse if there's already an unowned
    # active goal we'd duplicate accidentally.
    EXISTING_FILE=""; EXISTING_STATUS=""; EXISTING_GID=""
    if [ -n "$SID" ]; then
        OWNED_PTR="$ROOT/.goal/sessions/$SID"
        if [ -f "$OWNED_PTR" ] && [ ! -L "$OWNED_PTR" ]; then
            OWNED_GID=$(tr -d ' \t\r\n' < "$OWNED_PTR" 2>/dev/null || true)
            if valid_uuid "$OWNED_GID"; then
                OWNED_FILE="$ROOT/.goal/goals/$OWNED_GID.json"
                if [ -f "$OWNED_FILE" ] && [ ! -L "$OWNED_FILE" ]; then
                    EXISTING_FILE="$OWNED_FILE"
                    EXISTING_GID="$OWNED_GID"
                    EXISTING_STATUS=$(jq -r '.status // ""' "$EXISTING_FILE" 2>/dev/null || echo "")
                fi
            fi
        fi
    elif [ -n "$GOAL_OVERRIDE" ] && [ -f "$ROOT/.goal/goals/$GOAL_OVERRIDE.json" ]; then
        EXISTING_FILE="$ROOT/.goal/goals/$GOAL_OVERRIDE.json"
        EXISTING_GID="$GOAL_OVERRIDE"
        EXISTING_STATUS=$(jq -r '.status // ""' "$EXISTING_FILE" 2>/dev/null || echo "")
    elif [ -d "$ROOT/.goal/goals" ]; then
        # No session and no explicit --goal — fall back to "any active goal" so
        # CI scripts can't accidentally create a duplicate they'd never resolve.
        for _f in "$ROOT/.goal/goals"/*.json; do
            [ -f "$_f" ] && [ ! -L "$_f" ] || continue
            _st=$(jq -r '.status // ""' "$_f" 2>/dev/null || echo "")
            case "$_st" in
                pursuing|paused|needs-input)
                    EXISTING_FILE="$_f"
                    EXISTING_GID=$(basename "$_f" .json)
                    EXISTING_STATUS="$_st"
                    break ;;
            esac
        done
    fi

    if [ "$CMD" = "create" ] && [ -n "$EXISTING_FILE" ]; then
        case "$EXISTING_STATUS" in
            pursuing|paused|needs-input)
                if [ -n "$SID" ]; then
                    die "this session already owns a $EXISTING_STATUS goal ($EXISTING_GID); use 'goalctl replace' to overwrite or 'clear' first"
                else
                    die "a $EXISTING_STATUS goal already exists ($EXISTING_GID) and no CLAUDE_SESSION_ID was provided to bind a different one; use 'goalctl replace' or pass --session"
                fi
                ;;
        esac
    fi

    NEW_ID=$(new_uuid)
    NEW_FILE="$ROOT/.goal/goals/$NEW_ID.json"
    ACTION="create"
    [ -n "$EXISTING_FILE" ] && ACTION="replace"

    # Optional anti-loop hint from archived goals.
    SIMILAR_NOTE=""
    if [ -d "$ROOT/.goal/history" ]; then
        FIRST_WORD=$(printf '%s' "$OBJECTIVE" | awk '{print tolower($1)}')
        if [ -n "$FIRST_WORD" ]; then
            SIMILAR_NOTE=$(find "$ROOT/.goal/history" -maxdepth 3 \( -name state.json -o -name '*.json' \) 2>/dev/null | while IFS= read -r _sf; do
                _obj=$(jq -r '.objective // ""' "$_sf" 2>/dev/null)
                _status=$(jq -r '.status // "unknown"' "$_sf" 2>/dev/null)
                printf '%s' "$_obj" | tr '[:upper:]' '[:lower:]' | grep -q "$FIRST_WORD" || continue
                printf '%s: %s\n' "$_status" "$_obj"
            done | head -3)
            [ -n "$SIMILAR_NOTE" ] && printf 'Similar past goals:\n%s\n' "$SIMILAR_NOTE" >&2
        fi
    fi

    AUDIT_JSON="null"
    STRUCTURED_BUDGET="null"
    ROLE_JSON='{ "lead": null, "build": null, "review": null }'
    if [ "$TEMPLATE" = "tdd-feature" ] || [ "$TEMPLATE" = "migration" ] || [ "$TEMPLATE" = "bug-fix" ] || [ "$TEMPLATE" = "dependency-upgrade" ]; then
        case "$TEMPLATE" in
            tdd-feature)        P1="failing test captures behavior"; P2="implementation passes focused test"; P3="regression suite passes" ;;
            migration)          P1="migration path is compatible"; P2="rollback or recovery path documented"; P3="migration smoke test passes" ;;
            bug-fix)            P1="reproduction test captures bug"; P2="fix passes reproduction"; P3="adjacent regression suite passes" ;;
            dependency-upgrade) P1="lockfile updated"; P2="build and tests pass"; P3="compatibility risk documented" ;;
        esac
        AUDIT_JSON=$(jq -n --arg p1 "$P1" --arg p2 "$P2" --arg p3 "$P3" \
            '{checklist:[{id:"a1",predicate:$p1,status:"open",evidence:null},{id:"a2",predicate:$p2,status:"open",evidence:null},{id:"a3",predicate:$p3,status:"open",evidence:null}]}')
        STRUCTURED_BUDGET='{ "kind": "tokens", "limit": 50000, "used": 0 }'
        ROLE_JSON='{ "lead": "claude", "build": "codex", "review": "claude" }'
        [ "$BUDGET" = "null" ] && BUDGET=50000
        printf 'instantiating template %s: 3 audit items, 50000-token budget, lead/build/review roles\n' "$TEMPLATE" >&2
    elif [ "$QUICK" -ne 1 ]; then
        AUDIT_JSON=$(jq -n \
            '{checklist:[
              {id:"a1",predicate:"implementation satisfies the objective",status:"open",evidence:null},
              {id:"a2",predicate:"relevant tests or smoke checks pass",status:"open",evidence:null},
              {id:"a3",predicate:"documentation or user-facing output is accurate when applicable",status:"open",evidence:null}
            ]}')
    fi
    if [ "$DECOMPOSE" -eq 1 ]; then
        printf '{"at":"%s","objective":"%s — part 2","status":"pending"}\n' "$NOW" "$OBJECTIVE" >> "$ROOT/.goal/backlog.jsonl"
        printf '{"at":"%s","objective":"%s — verification","status":"pending"}\n' "$NOW" "$OBJECTIVE" >> "$ROOT/.goal/backlog.jsonl"
    fi
    # Clear stale baseline files from previous goal_id.
    rm -f "$ROOT/.claude/goal-baseline-"* 2>/dev/null || true

    # Build the new record JSON via the project-coord lock.
    CURRENT_SESSION="null"
    if [ -n "$SID" ]; then
        CURRENT_SESSION=$(printf '%s' "$SID" | jq -Rs .)
    fi
    write_new_record "$NEW_FILE" \
        jq -n --arg gid "$NEW_ID" --arg obj "$OBJECTIVE" --arg ts "$NOW" \
              --argjson budget "$BUDGET" --arg action "$ACTION" \
              --argjson audit "$AUDIT_JSON" --argjson roles "$ROLE_JSON" \
              --argjson sbudget "$STRUCTURED_BUDGET" --argjson session "$CURRENT_SESSION" \
        '{schema_version: 2,
          goal_id: $gid, objective: $obj, status: "pursuing",
          created_at: $ts, updated_at: $ts,
          time_used_seconds: 0, observed_at: $ts, active_turn_started_at: $ts,
          tokens_used_observed_at: $ts,
          time_used_seconds_final: null, tokens_used_final: null,
          token_budget: $budget, tokens_used: 0, tick_count: 0,
          pursuing_seconds: 0, pursuing_since: $ts,
          compat: ["claude-code"],
          roles: $roles,
          current: {agent: null, session: $session, since: (if $session == null then null else $ts end)},
          budget: $sbudget,
          lineage: [],
          audit: $audit, handoff_head: null, queued_until: null,
          history: [{ts: $ts, action: $action, note: "via goalctl"}]}'

    # On replace: remove the old record + any stale session pointer naming it.
    if [ "$ACTION" = "replace" ] && [ -n "$EXISTING_GID" ] && [ "$EXISTING_GID" != "$NEW_ID" ]; then
        rm -f "$ROOT/.goal/goals/$EXISTING_GID.json" 2>/dev/null || true
        rm -rf "$ROOT/.goal/locks/$EXISTING_GID.lock" 2>/dev/null || true
        # Drop any session pointers naming the replaced gid.
        if [ -d "$ROOT/.goal/sessions" ]; then
            for _p in "$ROOT/.goal/sessions"/*; do
                [ -f "$_p" ] || continue
                if grep -qxF "$EXISTING_GID" "$_p" 2>/dev/null; then
                    rm -f "$_p" 2>/dev/null || true
                fi
            done
        fi
    fi

    # Bind THIS session to the new goal, if a session id is available.
    if [ -n "$SID" ]; then
        atomic_write_session_pointer "$SID" "$NEW_ID"
    fi
    if [ -n "$SIMILAR_NOTE" ]; then
        printf '## Similar Goals\n%s\n' "$SIMILAR_NOTE" > "$ROOT/.goal/preamble.md"
    fi
    # Log to events.jsonl so the MCP/channel watchers see the change.
    printf '{"ts":"%s","type":"goal.created","goal_id":"%s","objective":"%s","actor":"goalctl","owner_session_id":%s,"token_budget":%s}\n' \
        "$NOW" "$NEW_ID" \
        "$(printf '%s' "$OBJECTIVE" | jq -Rs . | jq -r .)" \
        "$CURRENT_SESSION" "$BUDGET" \
        >> "$ROOT/.goal/events.jsonl" 2>/dev/null || true

    printf 'goal %s: %s\n' "$ACTION" "$NEW_ID"
    ;;

adopt)
    _TARGET="${ARGS[0]:-}"
    [ -n "$_TARGET" ] || die "adopt: goal_id required"
    valid_uuid "$_TARGET" || die "adopt: invalid goal_id: $_TARGET"
    [ -n "$SID" ] || die "adopt: no session id (set CLAUDE_SESSION_ID, GOAL_SESSION_ID, or pass --session)"
    _RECORD="$ROOT/.goal/goals/$_TARGET.json"
    [ -f "$_RECORD" ] && [ ! -L "$_RECORD" ] || die "adopt: no record at $_RECORD"
    ensure_dir
    atomic_write_session_pointer "$SID" "$_TARGET"
    printf '{"ts":"%s","type":"goal.adopted","goal_id":"%s","actor":"goalctl","owner_session_id":"%s"}\n' \
        "$NOW" "$_TARGET" "$SID" >> "$ROOT/.goal/events.jsonl" 2>/dev/null || true
    if [ "$JSON_OUTPUT" -eq 1 ]; then
        jq -n --arg gid "$_TARGET" --arg sid "$SID" '{ok:true,adopted:$gid,session_id:$sid}'
    else
        printf 'session %s adopted goal %s\n' "$SID" "$_TARGET"
    fi
    ;;

list)
    _GDIR="$ROOT/.goal/goals"
    if [ ! -d "$_GDIR" ]; then
        if [ "$JSON_OUTPUT" -eq 1 ]; then printf '{"goals":[]}\n'; else printf 'no goals in %s\n' "$_GDIR"; fi
        exit 0
    fi
    if [ "$JSON_OUTPUT" -eq 1 ]; then
        jq -n --argjson goals "$(for _f in "$_GDIR"/*.json; do
            [ -f "$_f" ] || continue
            jq -c '{goal_id, status, objective: (.objective | .[0:120]), updated_at}' "$_f" 2>/dev/null
        done | jq -s .)" '{goals:$goals}'
    else
        printf '%-36s  %-12s  %s\n' "goal_id" "status" "objective"
        for _f in "$_GDIR"/*.json; do
            [ -f "$_f" ] || continue
            jq -r '"\(.goal_id)  \(.status | (. + "            ") | .[0:12])  \(.objective[:80])"' "$_f" 2>/dev/null
        done
    fi
    ;;

get)
    ensure_exists
    # `get` already emits raw goal.json. `--json` is accepted for symmetry; it
    # ensures jq-validated pretty output rather than the file's literal bytes.
    if [ "$JSON_OUTPUT" -eq 1 ]; then
        jq '.' "$FILE"
    else
        cat "$FILE"
    fi
    ;;

status)
    ensure_exists
    if [ "$JSON_OUTPUT" -eq 1 ]; then
        # Structured status object with computed fields.
        # remaining_tokens: token_budget - tokens_used (or null if no budget)
        # elapsed_seconds: now - created_at (UTC)
        # last_action / last_note: from the tail of .history (or null)
        NOW_EPOCH=$(date -u +%s)
        jq --argjson now "$NOW_EPOCH" '
            . as $g
            | (try ($g.pursuing_since | fromdateiso8601) catch null) as $since
            | (try ($g.created_at    | fromdateiso8601) catch null) as $created
            # Backward-compat: legacy file with status=pursuing but no
            # pursuing_since → approximate active time from created_at.
            | (if $since != null then $since
               elif $g.status == "pursuing" and $created != null then $created
               else null end) as $start
            | (($g.pursuing_seconds // 0) | floor) as $base
            | (if $g.status == "pursuing" and $start != null
                  then $base + (($now - ($start | floor)) | (if . < 0 then 0 else . end))
                  else $base
              end) as $elapsed
            | {
                objective: $g.objective,
                status: $g.status,
                created_at: $g.created_at,
                updated_at: $g.updated_at,
                token_budget: $g.token_budget,
                tokens_used: ($g.tokens_used // 0),
                remaining_tokens: (if $g.token_budget == null then null
                                   else ($g.token_budget - ($g.tokens_used // 0)) end),
                elapsed_seconds: $elapsed,
                pursuing_seconds: ($g.pursuing_seconds // 0),
                pursuing_since: ($g.pursuing_since // null),
                tick_count: ($g.tick_count // 0),
                last_action: ($g.history // [] | last | .action // null),
                last_note: ($g.history // [] | last | .note // null)
              }
        ' "$FILE"
    else
        jq -r '
          "Goal: \(.objective[:80])\(if (.objective | length) > 80 then "..." else "" end)
Status: \(.status)
Set: \(.created_at)
Tokens: \(.tokens_used)\(if .token_budget then " / \(.token_budget)" else " (no budget)" end)
Ticks: \(.tick_count // 0)"
        ' "$FILE"
    fi
    ;;

pause)
    ensure_exists
    [ "$(read_field '.status')" = "pursuing" ] || die "can only pause a pursuing goal (current: $(read_field '.status'))"
    DELTA=$(compute_pursuit_seconds "$FILE")
    is_int_value() { case "$1" in ''|*[!0-9]*) return 1 ;; *) return 0 ;; esac; }
    is_int_value "$DELTA" || DELTA=0
    append_history "pause" "via goalctl"
    write_state ".status = \"paused\"
        | .pursuing_seconds = ((.pursuing_seconds // 0) + ${DELTA})
        | .pursuing_since = null"
    printf 'paused\n'
    ;;

resume)
    ensure_exists
    [ "$(read_field '.status')" = "paused" ] || die "can only resume a paused goal (current: $(read_field '.status'))"
    append_history "resume" "via goalctl"
    write_state '.status = "pursuing" | .pursuing_since = $ts'
    printf 'resumed\n'
    ;;

clear)
    ensure_exists
    # v3: remove the resolved goal record + any session pointers naming it +
    # its per-goal lock. The .goal/ tree, events.jsonl, lanes.json, and other
    # goals stay intact — clear is per-goal, not project-wide.
    rm -f "$FILE" 2>/dev/null || true
    rm -rf "$ROOT/.goal/locks/$GID.lock" 2>/dev/null || true
    rm -rf "$ROOT/.goal/cursors/$GID" 2>/dev/null || true
    if [ -d "$ROOT/.goal/sessions" ]; then
        for _p in "$ROOT/.goal/sessions"/*; do
            [ -f "$_p" ] || continue
            grep -qxF "$GID" "$_p" 2>/dev/null && rm -f "$_p" 2>/dev/null || true
        done
    fi
    # Legacy clean-up: if a v2 state.json or v1 file still happens to name this
    # gid (e.g. mid-migration crash), drop them too.
    if [ -f "$ROOT/.goal/state.json" ]; then
        _legacy_gid=$(jq -r '.goal_id // ""' "$ROOT/.goal/state.json" 2>/dev/null || echo "")
        [ "$_legacy_gid" = "$GID" ] && rm -f "$ROOT/.goal/state.json" 2>/dev/null || true
    fi
    rm -f "$ROOT/.claude/goal-baseline-$GID"* 2>/dev/null || true
    printf '{"ts":"%s","type":"goal.cleared","goal_id":"%s","actor":"goalctl"}\n' \
        "$NOW" "$GID" >> "$ROOT/.goal/events.jsonl" 2>/dev/null || true
    if [ "$JSON_OUTPUT" -eq 1 ]; then
        jq -n --arg gid "$GID" '{ok:true,cleared:$gid}'
    else
        printf 'cleared %s\n' "$GID"
    fi
    ;;

set-budget)
    ensure_exists
    VAL="${ARGS[0]:-}"
    [ -z "$VAL" ] && die "set-budget: value required (positive int or 'none')"
    if [ "$VAL" = "none" ] || [ "$VAL" = "null" ]; then
        append_history "set-budget" "cleared"
        write_state '.token_budget = null'
        printf 'budget cleared\n'
    else
        [[ "$VAL" =~ ^[1-9][0-9]*$ ]] || die "set-budget: must be a positive integer or 'none'"
        append_history "set-budget" "$VAL"
        write_state ".token_budget = ($VAL | tonumber)"
        printf 'budget set to %s\n' "$VAL"
    fi
    ;;

mark-achieved)
    ensure_exists
    CUR_STATUS=$(read_field '.status')
    if [ "$CUR_STATUS" = "pursuing" ]; then
        DELTA=$(compute_pursuit_seconds "$FILE")
        case "$DELTA" in ''|*[!0-9]*) DELTA=0 ;; esac
        append_history "mark-achieved" "via goalctl"
        write_state ".status = \"achieved\"
            | .pursuing_seconds = ((.pursuing_seconds // 0) + ${DELTA})
            | .time_used_seconds = ((.time_used_seconds // .pursuing_seconds // 0) + ${DELTA})
            | .observed_at = \$ts
            | .active_turn_started_at = null
            | .time_used_seconds_final = (.time_used_seconds // ((.pursuing_seconds // 0) + ${DELTA}))
            | .tokens_used_final = (.tokens_used // 0)
            | .pursuing_since = null"
    else
        append_history "mark-achieved" "via goalctl"
        write_state '.status = "achieved" | .pursuing_since = null'
    fi
    printf 'marked achieved\n'
    ;;

mark-unmet)
    die "v3 has no 'unmet' state. A stuck goal parks to 'needs-input' automatically (resumable). Only the user clears a goal: 'goalctl clear' (per-goal)."
    ;;

listen)
    # tail -F .goal/events.jsonl with optional --grep and --since.
    # Args supported (consumed from ARGS):
    #   --grep <pattern>    grep -E filter on lines as they arrive
    #   --since <iso8601>   print existing lines whose .ts >= since, then tail
    ensure_dir
    EVENTS_FILE="$ROOT/.goal/events.jsonl"
    [ -f "$EVENTS_FILE" ] || : > "$EVENTS_FILE"

    GREP_PAT=""
    SINCE_ISO=""
    i=0
    while [ "$i" -lt "${#ARGS[@]}" ]; do
        case "${ARGS[$i]}" in
            --grep)
                GREP_PAT="${ARGS[$((i+1))]:-}"
                [ -z "$GREP_PAT" ] && die "listen --grep: pattern required"
                i=$((i+2))
                ;;
            --since)
                SINCE_ISO="${ARGS[$((i+1))]:-}"
                [ -z "$SINCE_ISO" ] && die "listen --since: ISO8601 timestamp required"
                i=$((i+2))
                ;;
            *)
                die "listen: unknown arg: ${ARGS[$i]}"
                ;;
        esac
    done

    # Backfill --since events (best-effort: filter existing lines by .ts >= since).
    if [ -n "$SINCE_ISO" ]; then
        # Validate ISO and grab any existing events whose ts >= since.
        if [ -s "$EVENTS_FILE" ]; then
            BACKFILL=$(jq -rR --arg since "$SINCE_ISO" '
                . as $line
                | (try (fromjson) catch null) as $obj
                | if $obj == null then empty
                  else
                    (try ($obj.ts | fromdateiso8601) catch null) as $t
                    | (try ($since | fromdateiso8601) catch null) as $s
                    | if $t == null or $s == null or $t >= $s then $line else empty end
                  end
            ' "$EVENTS_FILE" 2>/dev/null || true)
            if [ -n "$BACKFILL" ]; then
                if [ -n "$GREP_PAT" ]; then
                    printf '%s\n' "$BACKFILL" | grep -E "$GREP_PAT" || true
                else
                    printf '%s\n' "$BACKFILL"
                fi
            fi
        fi
        # Now tail only NEW lines (-n 0).
        if [ -n "$GREP_PAT" ]; then
            exec tail -n 0 -F "$EVENTS_FILE" | grep --line-buffered -E "$GREP_PAT"
        else
            exec tail -n 0 -F "$EVENTS_FILE"
        fi
    fi

    if [ -n "$GREP_PAT" ]; then
        exec tail -F "$EVENTS_FILE" | grep --line-buffered -E "$GREP_PAT"
    else
        exec tail -F "$EVENTS_FILE"
    fi
    ;;

serve-http)
    # Hand off to the Node HTTP shim.
    PORT=7474
    i=0
    while [ "$i" -lt "${#ARGS[@]}" ]; do
        case "${ARGS[$i]}" in
            --port)
                PORT="${ARGS[$((i+1))]:-}"
                [ -z "$PORT" ] && die "serve-http --port: value required"
                i=$((i+2))
                ;;
            *)
                die "serve-http: unknown arg: ${ARGS[$i]}"
                ;;
        esac
    done
    [[ "$PORT" =~ ^[1-9][0-9]*$ ]] || die "serve-http: --port must be a positive integer"
    [ "$PORT" -lt 65536 ] || die "serve-http: --port must be < 65536"
    ensure_dir
    SCRIPT_DIR=$(cd "$(dirname "$0")" && pwd)
    HTTP_SCRIPT="$SCRIPT_DIR/goal-http-server.ts"
    [ -f "$HTTP_SCRIPT" ] || die "goal-http-server.ts not found at $HTTP_SCRIPT"
    if node --experimental-strip-types -e 'process.exit(0)' >/dev/null 2>&1; then
        exec node --experimental-strip-types "$HTTP_SCRIPT" --port "$PORT" --root "$ROOT"
    fi
    if ! command -v npx >/dev/null 2>&1; then
        die "npx not found; install Node.js (>=18) to use 'goalctl serve-http'"
    fi
    exec npx tsx "$HTTP_SCRIPT" --port "$PORT" --root "$ROOT"
    ;;

bridge)
    # bridge start <runner> | bridge stop <runner>
    # P2 subset of §10's full bridge CLI (the rest lands in P5).
    #
    # bridge start <runner>:
    #   Spawns bin/goal-bridge <runner> --root $ROOT in background via nohup.
    #   stdout/stderr go to .goal/agents/<runner>.log.
    #   PID written to .goal/agents/<runner>.pid.
    #
    # bridge stop <runner>:
    #   Reads .goal/agents/<runner>.pid, sends SIGTERM, waits 3s, sends SIGKILL.
    #   Removes pid file. Idempotent if pid file missing.
    #
    # --json: emit structured JSON to stdout.

    BRIDGE_SUBCMD="${ARGS[0]:-}"
    BRIDGE_RUNNER="${ARGS[1]:-}"
    [ -n "$BRIDGE_SUBCMD" ] || die "bridge: subcommand required (start|stop)"
    [ -n "$BRIDGE_RUNNER" ] || die "bridge: runner required (e.g. codex, claude-code)"

    _BRIDGE_BIN="$(cd "$(dirname "$0")" && pwd)/goal-bridge"
    [ -f "$_BRIDGE_BIN" ] || die "bridge: goal-bridge not found at $_BRIDGE_BIN"

    _AGENTS_DIR="$ROOT/.goal/agents"
    mkdir -p "$_AGENTS_DIR" 2>/dev/null || true
    _PID_FILE="$_AGENTS_DIR/${BRIDGE_RUNNER}.pid"
    _LOG_FILE="$_AGENTS_DIR/${BRIDGE_RUNNER}.log"

    case "$BRIDGE_SUBCMD" in

    start)
        # Fail if already running (pid file exists and process is alive).
        if [ -f "$_PID_FILE" ]; then
            _OLD_PID=$(cat "$_PID_FILE" 2>/dev/null || true)
            if [ -n "$_OLD_PID" ] && kill -0 "$_OLD_PID" 2>/dev/null; then
                if [ "$JSON_OUTPUT" -eq 1 ]; then
                    jq -n --arg runner "$BRIDGE_RUNNER" --argjson pid "$_OLD_PID" \
                        '{ok: false, error: "already running", runner: $runner, pid: $pid}'
                else
                    die "bridge: runner '$BRIDGE_RUNNER' already running (pid $_OLD_PID). Use 'bridge stop' first."
                fi
                exit 1
            fi
            rm -f "$_PID_FILE" 2>/dev/null || true
        fi

        # Spawn bridge in background.
        nohup node "$_BRIDGE_BIN" "$BRIDGE_RUNNER" --root "$ROOT" \
            >> "$_LOG_FILE" 2>&1 &
        _NEW_PID=$!
        printf '%d\n' "$_NEW_PID" > "$_PID_FILE"

        if [ "$JSON_OUTPUT" -eq 1 ]; then
            jq -n --arg runner "$BRIDGE_RUNNER" --argjson pid "$_NEW_PID" \
                --arg log "$_LOG_FILE" --arg pid_file "$_PID_FILE" \
                '{ok: true, runner: $runner, pid: $pid, log: $log, pid_file: $pid_file}'
        else
            printf 'bridge started: runner=%s pid=%d log=%s\n' \
                "$BRIDGE_RUNNER" "$_NEW_PID" "$_LOG_FILE"
        fi
        ;;

    stop)
        if [ ! -f "$_PID_FILE" ]; then
            if [ "$JSON_OUTPUT" -eq 1 ]; then
                jq -n --arg runner "$BRIDGE_RUNNER" \
                    '{ok: true, runner: $runner, note: "not running (no pid file)"}'
            else
                printf 'bridge stop: runner=%s not running (no pid file)\n' "$BRIDGE_RUNNER"
            fi
            exit 0
        fi

        _STOP_PID=$(cat "$_PID_FILE" 2>/dev/null || true)
        if [ -z "$_STOP_PID" ]; then
            rm -f "$_PID_FILE" 2>/dev/null || true
            if [ "$JSON_OUTPUT" -eq 1 ]; then
                jq -n --arg runner "$BRIDGE_RUNNER" \
                    '{ok: true, runner: $runner, note: "pid file empty; removed"}'
            else
                printf 'bridge stop: pid file empty; removed\n'
            fi
            exit 0
        fi

        if ! kill -0 "$_STOP_PID" 2>/dev/null; then
            rm -f "$_PID_FILE" 2>/dev/null || true
            if [ "$JSON_OUTPUT" -eq 1 ]; then
                jq -n --arg runner "$BRIDGE_RUNNER" --argjson pid "$_STOP_PID" \
                    '{ok: true, runner: $runner, pid: $pid, note: "process not found; removed stale pid file"}'
            else
                printf 'bridge stop: runner=%s pid=%d not found; removed stale pid file\n' \
                    "$BRIDGE_RUNNER" "$_STOP_PID"
            fi
            exit 0
        fi

        # Send SIGTERM and wait up to 3s.
        kill -TERM "$_STOP_PID" 2>/dev/null || true
        _WAITED=0
        while [ "$_WAITED" -lt 30 ]; do
            kill -0 "$_STOP_PID" 2>/dev/null || break
            sleep 0.1
            _WAITED=$(( _WAITED + 1 ))
        done

        # SIGKILL if still alive.
        if kill -0 "$_STOP_PID" 2>/dev/null; then
            kill -KILL "$_STOP_PID" 2>/dev/null || true
            sleep 0.2
        fi

        rm -f "$_PID_FILE" 2>/dev/null || true

        if [ "$JSON_OUTPUT" -eq 1 ]; then
            jq -n --arg runner "$BRIDGE_RUNNER" --argjson pid "$_STOP_PID" \
                '{ok: true, runner: $runner, pid: $pid, note: "stopped"}'
        else
            printf 'bridge stopped: runner=%s pid=%d\n' "$BRIDGE_RUNNER" "$_STOP_PID"
        fi
        ;;

    *)
        die "bridge: unknown subcommand '$BRIDGE_SUBCMD' (use start|stop)"
        ;;
    esac
    ;;

handoff)
    # handoff list | handoff show <seq>
    # P5: §10 goalctl additions.
    HANDOFF_SUBCMD="${ARGS[0]:-}"
    [ -n "$HANDOFF_SUBCMD" ] || die "handoff: subcommand required (list|show)"

    _HANDOFF_DIR="$ROOT/.goal/handoff"

    case "$HANDOFF_SUBCMD" in

    list)
        # List all handoff envelopes sorted by seq ascending.
        if [ ! -d "$_HANDOFF_DIR" ]; then
            if [ "$JSON_OUTPUT" -eq 1 ]; then
                printf '{"handoffs":[]}\n'
            else
                printf 'No handoff envelopes found.\n'
            fi
            exit 0
        fi
        _FILES=$(ls -1 "$_HANDOFF_DIR"/*.md 2>/dev/null | sort || true)
        if [ -z "$_FILES" ]; then
            if [ "$JSON_OUTPUT" -eq 1 ]; then
                printf '{"handoffs":[]}\n'
            else
                printf 'No handoff envelopes found.\n'
            fi
            exit 0
        fi
        if [ "$JSON_OUTPUT" -eq 1 ]; then
            # Build JSON array from frontmatter fields.
            printf '{"handoffs":['
            _first=1
            for _f in $_FILES; do
                [ -f "$_f" ] || continue
                _seq=$(awk '/^---/{if(++c==1)next;if(c==2)exit} c==1 && /^seq:/{gsub(/^seq:[[:space:]]*/,"");print;exit}' "$_f" 2>/dev/null || echo "")
                _from=$(awk '/^---/{if(++c==1)next;if(c==2)exit} c==1 && /^from:/{gsub(/^from:[[:space:]]*/,"");print;exit}' "$_f" 2>/dev/null || echo "")
                _to=$(awk '/^---/{if(++c==1)next;if(c==2)exit} c==1 && /^to:/{gsub(/^to:[[:space:]]*/,"");print;exit}' "$_f" 2>/dev/null || echo "")
                _at=$(awk '/^---/{if(++c==1)next;if(c==2)exit} c==1 && /^at:/{gsub(/^at:[[:space:]]*/,"");print;exit}' "$_f" 2>/dev/null || echo "")
                _reason=$(awk '/^---/{if(++c==1)next;if(c==2)exit} c==1 && /^reason:/{gsub(/^reason:[[:space:]]*/,"");print;exit}' "$_f" 2>/dev/null || echo "")
                [ "$_first" -eq 1 ] || printf ','
                _first=0
                jq -n --arg seq "$_seq" --arg from "$_from" --arg to "$_to" \
                      --arg at "$_at" --arg reason "$_reason" --arg path "$_f" \
                    '{seq:$seq,from:$from,to:$to,at:$at,reason:$reason,path:$path}'
            done
            printf ']}\n'
        else
            for _f in $_FILES; do
                [ -f "$_f" ] || continue
                _seq=$(awk '/^---/{if(++c==1)next;if(c==2)exit} c==1 && /^seq:/{gsub(/^seq:[[:space:]]*/,"");print;exit}' "$_f" 2>/dev/null || echo "?")
                _from=$(awk '/^---/{if(++c==1)next;if(c==2)exit} c==1 && /^from:/{gsub(/^from:[[:space:]]*/,"");print;exit}' "$_f" 2>/dev/null || echo "?")
                _to=$(awk '/^---/{if(++c==1)next;if(c==2)exit} c==1 && /^to:/{gsub(/^to:[[:space:]]*/,"");print;exit}' "$_f" 2>/dev/null || echo "?")
                _reason=$(awk '/^---/{if(++c==1)next;if(c==2)exit} c==1 && /^reason:/{gsub(/^reason:[[:space:]]*/,"");print;exit}' "$_f" 2>/dev/null || echo "?")
                printf '%s  %s→%s  %s\n' "$_seq" "$_from" "$_to" "$_reason"
            done
        fi
        ;;

    show)
        _SEQ="${ARGS[1]:-}"
        [ -n "$_SEQ" ] || die "handoff show: sequence number required"
        # Pad to 4 digits.
        _SEQ_PAD=$(printf '%04d' "$_SEQ" 2>/dev/null || printf '%s' "$_SEQ")
        _HFILE="$_HANDOFF_DIR/${_SEQ_PAD}.md"
        [ -f "$_HFILE" ] || die "handoff show: no envelope at $_HFILE"
        if [ "$JSON_OUTPUT" -eq 1 ]; then
            # Extract all frontmatter fields and content.
            _seq=$(awk '/^---/{if(++c==1)next;if(c==2)exit} c==1 && /^seq:/{gsub(/^seq:[[:space:]]*/,"");print;exit}' "$_HFILE" 2>/dev/null || echo "")
            _from=$(awk '/^---/{if(++c==1)next;if(c==2)exit} c==1 && /^from:/{gsub(/^from:[[:space:]]*/,"");print;exit}' "$_HFILE" 2>/dev/null || echo "")
            _to=$(awk '/^---/{if(++c==1)next;if(c==2)exit} c==1 && /^to:/{gsub(/^to:[[:space:]]*/,"");print;exit}' "$_HFILE" 2>/dev/null || echo "")
            _at=$(awk '/^---/{if(++c==1)next;if(c==2)exit} c==1 && /^at:/{gsub(/^at:[[:space:]]*/,"");print;exit}' "$_HFILE" 2>/dev/null || echo "")
            _reason=$(awk '/^---/{if(++c==1)next;if(c==2)exit} c==1 && /^reason:/{gsub(/^reason:[[:space:]]*/,"");print;exit}' "$_HFILE" 2>/dev/null || echo "")
            _gid=$(awk '/^---/{if(++c==1)next;if(c==2)exit} c==1 && /^goal_id:/{gsub(/^goal_id:[[:space:]]*/,"");print;exit}' "$_HFILE" 2>/dev/null || echo "")
            _content=$(cat "$_HFILE")
            jq -n --arg seq "$_seq" --arg from "$_from" --arg to "$_to" \
                  --arg at "$_at" --arg reason "$_reason" --arg goal_id "$_gid" \
                  --arg content "$_content" --arg path "$_HFILE" \
                '{seq:$seq,from:$from,to:$to,at:$at,reason:$reason,goal_id:$goal_id,path:$path,content:$content}'
        else
            cat "$_HFILE"
        fi
        ;;

    *)
        die "handoff: unknown subcommand '$HANDOFF_SUBCMD' (use list|show)"
        ;;
    esac
    ;;

lanes)
    # lanes                  — list active leases
    # lanes release <id>     — release a lease
    # P5: §10 goalctl additions. All under .goal/lanes.json.

    _LANES_SUBCMD="${ARGS[0]:-}"
    _LANES_FILE="$ROOT/.goal/lanes.json"
    _AGENTS_DIR="$ROOT/.goal/agents"

    _prune_lanes() {
        # Inline lazy pruning: remove expired or stale leases.
        [ -f "$_LANES_FILE" ] || return 0
        local _now_epoch
        _now_epoch=$(date +%s)
        local _hb_ttl="${GOAL_HEARTBEAT_TTL_MS:-15000}"
        _hb_ttl_s=$(( _hb_ttl / 1000 ))

        jq --argjson now "$_now_epoch" --argjson hb_ttl_s "$_hb_ttl_s" \
            --arg agents_dir "$_AGENTS_DIR" '
            .leases |= map(
              . as $lease |
              (try ($lease.acquired_at | fromdateiso8601) catch null) as $acq |
              ($acq != null and ($now - $acq) > $lease.ttl_seconds) as $expired |
              if $expired then empty
              else .
              end
            )
        ' "$_LANES_FILE" > "$_LANES_FILE.tmp" 2>/dev/null && \
        mv "$_LANES_FILE.tmp" "$_LANES_FILE" 2>/dev/null || \
        rm -f "$_LANES_FILE.tmp" 2>/dev/null || true
    }

    case "${_LANES_SUBCMD}" in

    release)
        _LEASE_ID="${ARGS[1]:-}"
        [ -n "$_LEASE_ID" ] || die "lanes release: lease_id required"
        [ -f "$_LANES_FILE" ] || die "lanes release: no lanes.json at $_LANES_FILE"
        _LANES_LOCK="$ROOT/.goal/locks/_coord.lock"
        mkdir -p "$(dirname "$_LANES_LOCK")" 2>/dev/null || true
        if ! goal_lock_acquire "$_LANES_LOCK"; then
            die "lanes release: could not acquire $_LANES_LOCK"
        fi
        trap 'goal_lock_release "$_LANES_LOCK"' EXIT INT TERM
        _prune_lanes

        _BEFORE=$(jq '.leases | length' "$_LANES_FILE" 2>/dev/null || echo 0)
        jq --arg lid "$_LEASE_ID" '.leases |= map(select(.lease_id != $lid))' \
            "$_LANES_FILE" > "$_LANES_FILE.tmp" 2>/dev/null && \
            mv "$_LANES_FILE.tmp" "$_LANES_FILE" 2>/dev/null || \
            { rm -f "$_LANES_FILE.tmp" 2>/dev/null; die "lanes release: jq failed"; }
        _AFTER=$(jq '.leases | length' "$_LANES_FILE" 2>/dev/null || echo 0)

        goal_lock_release "$_LANES_LOCK"
        trap - EXIT INT TERM

        if [ "$_BEFORE" -gt "$_AFTER" ]; then
            if [ "$JSON_OUTPUT" -eq 1 ]; then
                jq -n --arg lid "$_LEASE_ID" '{ok:true,released:$lid}'
            else
                printf 'released: %s\n' "$_LEASE_ID"
            fi
        else
            if [ "$JSON_OUTPUT" -eq 1 ]; then
                jq -n --arg lid "$_LEASE_ID" '{ok:false,note:"lease not found"}'
            else
                printf 'lease not found: %s\n' "$_LEASE_ID"
            fi
            exit 1
        fi
        ;;

    "")
        # List active leases (with lazy pruning).
        _prune_lanes

        if [ ! -f "$_LANES_FILE" ]; then
            if [ "$JSON_OUTPUT" -eq 1 ]; then
                printf '{"leases":[]}\n'
            else
                printf 'No active lane leases.\n'
            fi
            exit 0
        fi

        if [ "$JSON_OUTPUT" -eq 1 ]; then
            cat "$_LANES_FILE"
        else
            _COUNT=$(jq '.leases | length' "$_LANES_FILE" 2>/dev/null || echo 0)
            if [ "$_COUNT" -eq 0 ]; then
                printf 'No active lane leases.\n'
            else
                printf 'Active lane leases (%s):\n' "$_COUNT"
                jq -r '.leases[] | "  \(.lease_id | .[0:8])...  glob=\(.glob)  holder=\(.holder)  ttl=\(.ttl_seconds)s  reason=\(.reason)"' \
                    "$_LANES_FILE" 2>/dev/null || cat "$_LANES_FILE"
            fi
        fi
        ;;

    *)
        die "lanes: unknown subcommand '${_LANES_SUBCMD}' (use: lanes | lanes release <lease_id>)"
        ;;
    esac
    ;;

relay)
    # Force relay to peer by writing a fault signal.
    # P5: §10 goalctl additions.
    ensure_exists

    _STATE_AGENT=$(jq -r '.current.agent // ""' "$FILE" 2>/dev/null)
    [ -n "$_STATE_AGENT" ] || die "relay: no current.agent in $FILE — is a bridge running?"

    _FAULT_FILE="$ROOT/.goal/agents/${_STATE_AGENT}.fault"
    mkdir -p "$(dirname "$_FAULT_FILE")" 2>/dev/null || true

    _FAULT_JSON=$(jq -n --arg ts "$(date -u +%FT%TZ)" --arg agent "$_STATE_AGENT" \
        '{kind:"other",reason:"user",at:$ts,payload:"goalctl relay: forced relay",event_type:"goalctl_relay"}')
    printf '%s\n' "$_FAULT_JSON" > "$_FAULT_FILE.tmp" && \
        mv "$_FAULT_FILE.tmp" "$_FAULT_FILE" 2>/dev/null || \
        { rm -f "$_FAULT_FILE.tmp" 2>/dev/null; die "relay: could not write fault file"; }

    if [ "$JSON_OUTPUT" -eq 1 ]; then
        jq -n --arg agent "$_STATE_AGENT" --arg fault "$_FAULT_FILE" \
            '{ok:true,note:"fault signal written; bridge will pick up within one tick",agent:$agent,fault_file:$fault}'
    else
        printf 'relay: fault signal written for agent %s\n' "$_STATE_AGENT"
        printf '       bridge will pick up within one tick (500ms debounce).\n'
    fi
    ;;

quota)
    # Show provider headroom from .goal/quota.json.
    # P5: §10 goalctl additions.
    _QUOTA_FILE="$ROOT/.goal/quota.json"
    if [ ! -f "$_QUOTA_FILE" ]; then
        if [ "$JSON_OUTPUT" -eq 1 ]; then
            printf '{"providers":{},"note":"quota.json not found"}\n'
        else
            printf 'No quota.json found at %s\n' "$_QUOTA_FILE"
        fi
        exit 0
    fi
    if [ "$JSON_OUTPUT" -eq 1 ]; then
        cat "$_QUOTA_FILE"
    else
        jq -r '
            .providers // {} | to_entries[] |
            "  \(.key): headroom=\(.value.estimated_headroom // "unknown")  consecutive_429=\(.value.consecutive_429 // 0)  reset_at=\(.value.limit_reset_at // "N/A")"
        ' "$_QUOTA_FILE" 2>/dev/null | { printf 'Provider quota:\n'; cat; } || cat "$_QUOTA_FILE"
    fi
    ;;

cowork)
    # cowork init — write default .goal/cowork.yml
    # P5: §10 goalctl additions.
    _COWORK_SUBCMD="${ARGS[0]:-}"
    case "$_COWORK_SUBCMD" in
    init)
        _GOAL_DIR="$ROOT/.goal"
        mkdir -p "$_GOAL_DIR" 2>/dev/null || true
        _COWORK_FILE="$_GOAL_DIR/cowork.yml"
        if [ -f "$_COWORK_FILE" ]; then
            die "cowork init: $_COWORK_FILE already exists. Delete it first to re-initialize."
        fi
        cat > "$_COWORK_FILE" <<'COWORK_YML'
version: 1
agents:
  claude:
    runner: claude-code
    model: default
  codex:
    runner: codex
    model: default
roles:
  lead:   claude
  build:  codex
  review: claude
relay:
  on_rate_limit:        true
  on_5xx:               true
  small_model_offload:  false   # opt-in
heartbeat_ttl_seconds:  15
COWORK_YML
        if [ "$JSON_OUTPUT" -eq 1 ]; then
            jq -n --arg path "$_COWORK_FILE" '{ok:true,path:$path,note:"default cowork.yml written"}'
        else
            printf 'cowork.yml written: %s\n' "$_COWORK_FILE"
            printf 'Edit it to assign runners and roles for your agents.\n'
        fi
        ;;
    "")
        die "cowork: subcommand required (init)"
        ;;
    *)
        die "cowork: unknown subcommand '$_COWORK_SUBCMD' (use: cowork init)"
        ;;
    esac
    ;;

*)
    usage
    die "unknown command: $CMD"
    ;;
esac
