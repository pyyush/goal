{
  "$schema": "https://json.schemastore.org/claude-code-plugin-manifest.json",
  "name": "goal",
  "version": "0.1.1",
  "description": "Persistent objective lifecycle for Claude Code: set a goal once, Claude pursues across turns until done.",
  "author": {
    "name": "pyyush",
    "url": "https://github.com/pyyush"
  },
  "homepage": "https://github.com/pyyush/goal",
  "repository": "https://github.com/pyyush/goal",
  "license": "MIT",
  "keywords": ["goal", "objective", "persistence", "agent", "autonomy", "lifecycle"],
  "commands": ["./goal.md"],
  "hooks": {
    "hooks": {
      "Stop": [
        {
          "hooks": [
            {
              "type": "command",
              "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/goal-stop.sh"
            }
          ]
        }
      ],
      "Notification": [
        {
          "hooks": [
            {
              "type": "command",
              "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/goal-notify.sh"
            }
          ]
        }
      ],
      "UserPromptSubmit": [
        {
          "hooks": [
            {
              "type": "command",
              "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/goal-prompt.sh"
            }
          ]
        }
      ]
    }
  },
  "mcpServers": {
    "goal": {
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/mcp/dist/goal-server.js"],
      "env": {
        "GOAL_PLUGIN_ROOT": "${CLAUDE_PLUGIN_ROOT}"
      }
    }
  },
  "channels": [
    {
      "server": "goal"
    }
  ]
}
